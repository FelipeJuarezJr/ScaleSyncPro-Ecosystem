rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // General User document rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subcollection for User Reptiles
      match /reptiles/{reptileId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /{document=**} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Subcollection for User Breeding Logs
      match /breeding_logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /{document=**} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Subcollection for User Clutches
      match /clutches/{clutchId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Subcollection for User Schedules
      match /schedules/{scheduleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Subcollection for User Expenses
      match /expenses/{expenseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /{document=**} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // Helper functions for validation
    function isOwner(uid) {
      return request.auth != null && uid == request.auth.uid;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Social Media Feeds (posts collection and social_posts collection)
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
        && request.resource.data.uid == request.auth.uid 
        && request.resource.data.keys().hasAny(['uid']);
      allow update: if request.auth != null && (
        resource.data.uid == request.auth.uid 
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'recentLikers', 'likesMap'])
      );
      allow delete: if request.auth != null && (
        resource.data.uid == request.auth.uid 
        || request.auth.token.admin == true
      );

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null 
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.keys().hasAny(['uid']);
        allow update, delete: if request.auth != null 
          && (resource.data.uid == request.auth.uid || request.auth.token.admin == true);
      }
    }

    match /social_posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
        && request.resource.data.uid == request.auth.uid 
        && request.resource.data.keys().hasAny(['uid']);
      allow update: if request.auth != null && (
        resource.data.uid == request.auth.uid 
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'recentLikers', 'likesMap'])
      );
      allow delete: if request.auth != null && (
        resource.data.uid == request.auth.uid 
        || request.auth.token.admin == true
      );
    }

    // Internal Marketplace Listings
    match /listings/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAny(['uid']);
      allow update, delete: if request.auth != null 
        && (resource.data.uid == request.auth.uid || request.auth.token.admin == true);
    }

    // Public Marketplace Listings (strictly validating structural types for pedigree snapshot and single photo download URL)
    match /marketplace_listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null 
        && request.resource.data.sellerId == request.auth.uid
        && (request.resource.data.verifiedPedigreeSnapshot == null || request.resource.data.verifiedPedigreeSnapshot is list);
      allow update: if request.auth != null 
        && (resource.data.sellerId == request.auth.uid || request.auth.token.admin == true)
        && (request.resource.data.verifiedPedigreeSnapshot == null || request.resource.data.verifiedPedigreeSnapshot is list);
      allow delete: if request.auth != null 
        && (resource.data.sellerId == request.auth.uid || request.auth.token.admin == true);
    }

    // Direct Messaging Chat Threads (Regex-Based String Match Checks)
    match /chats/{chatId} {
      allow read, write: if request.auth != null 
        && (chatId.matches(request.auth.uid + '_.*') || chatId.matches('.*_' + request.auth.uid));

      match /messages/{messageId} {
        allow read, write: if request.auth != null 
          && (chatId.matches(request.auth.uid + '_.*') || chatId.matches('.*_' + request.auth.uid));
      }
    }

    // Admin Audit Logs (Requires Custom Admin Claim Verification)
    match /audit_logs/{logId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
